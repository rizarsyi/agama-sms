Flow org.gluu.agama.sms.otp
     Basepath ""
     Inputs credentials otpService maskedPhone
Log "@info Start retrieving OTP Code for user: " credentials.username
otpUiFeedback = {}
otpUiFeedback.maskedPhone = maskedPhone
// Retrieve code from user via UI
otpCreds = RRF "otp.ftlh" otpUiFeedback
// Log code retrieve from user via UI
Log "@info Code retrieve from the UI is:" otpCreds.code
otpValidationResult = Call otpService validateOTPCode credentials.username otpCreds.code
// Check if OTP validation has succeed
When otpValidationResult is true
     Finish otpValidationResult
otpUiFeedback.errorMessage = "The provided code is not valid."
Finish otpUiFeedback.errorMessage