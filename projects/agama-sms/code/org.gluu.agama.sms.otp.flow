Flow org.gluu.agama.sms.otp
     Basepath ""
     Inputs otpService username maskedPhone
Log "@info Information received by the called:" username maskedPhone
// Declare a variable for Ui feedback messages
otpUiFeedback = {}
otpUiFeedback.maskedPhone = maskedPhone
otpCount = Repeat 3 times max
     otpCreds = RRF "otp.ftlh" otpUiFeedback
     Log "@info OTP Code provided by the user is : " otpCreds.code
     otpValidationResult | otpValidationException = Call otpService validateOTPCode username otpCreds.code
     Log "@info OTP validation result is:" otpValidationResult otpValidationException
     // If otp validation was successful
     When otpValidationResult is true
          Finish otpValidationResult